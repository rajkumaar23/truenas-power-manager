# IPMI credentials for the backup TrueNAS BMC.
# The BMC must be reachable from the container (via WireGuard tunnel).
IPMI_HOST=10.10.0.64
IPMI_USER=ADMIN
IPMI_PASSWORD=changeme
# Optional — defaults to ADMINISTRATOR
# IPMI_PRIVILEGE=ADMINISTRATOR

# SSH credentials for the source TrueNAS.
# Used to check whether a replication task is still running before powering off.
TRUENAS_HOST=192.168.1.10
TRUENAS_USER=root
# Use either password or key-based auth:
TRUENAS_PASSWORD=changeme
# TRUENAS_KEY_FILE=/secrets/truenas_id_rsa
# Optional — defaults to 22
# TRUENAS_PORT=22
